<?xml version="1.0" encoding="UTF-8"?>
<!--
    Logback 日志配置文件
    位置: core/src/main/resources/logback.xml
    作用: 控制日志输出到控制台和文件
-->
<configuration>

    <!-- ============================================================
         1. 定义日志输出格式
         %d{yyyy-MM-dd HH:mm:ss}  - 时间戳
         [%thread]                 - 线程名
         %-5level                  - 日志级别（左对齐，占5位）
         %logger{36}               - 日志记录器名（类名），限36字符
         %msg                      - 日志消息
         %n                        - 换行
         ============================================================ -->
    <property name="LOG_PATTERN"
              value="%d{yyyy-MM-dd HH:mm:ss} [%thread] %-5level %logger{36} - %msg%n"/>

    <!-- 日志文件存放路径 -->
    <property name="LOG_PATH" value="logs"/>

    <!-- ============================================================
         2. 控制台输出 (ConsoleAppender)
         开发环境下使用，方便实时查看日志
         ============================================================ -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>${LOG_PATTERN}</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <!-- ============================================================
         3. 文件输出 (RollingFileAppender)
         生产环境下使用，支持日志滚动（按天分割）
         ============================================================ -->
    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <!-- 当前日志文件 -->
        <file>${LOG_PATH}/app.log</file>

        <!-- 滚动策略：按天生成新文件 -->
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <!-- 历史日志文件名格式 -->
            <fileNamePattern>${LOG_PATH}/app.%d{yyyy-MM-dd}.log</fileNamePattern>
            <!-- 保留最近30天的日志 -->
            <maxHistory>30</maxHistory>
        </rollingPolicy>

        <encoder>
            <pattern>${LOG_PATTERN}</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <!-- ============================================================
         4. 日志级别设置
         ============================================================ -->
    <!-- 根日志级别: INFO - 记录INFO及以上级别的日志 -->
    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="FILE"/>
    </root>

    <!-- 项目包级别: DEBUG - 记录项目代码的DEBUG及以上级别日志 -->
    <logger name="edu.gpnu.bigdata" level="DEBUG"/>

</configuration>